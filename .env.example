# Copy this file to .env and fill in your credentials.
# Never commit .env — it is gitignored. This file is safe to commit.
#
# Generate secure random strings with:
#   openssl rand -base64 32

# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Neon (https://neon.tech) recommended — free tier available.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Authentication ────────────────────────────────────────────────────────────
# Random secret used to sign session tokens. Min 32 characters.
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Required by NextAuth v5 in some configurations
AUTH_URL=http://localhost:3000

# GitHub OAuth App — create one at https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=your-github-oauth-client-id
AUTH_GITHUB_SECRET=your-github-oauth-client-secret

# ─── AI (Anthropic Claude) ─────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Payments (Stripe) ─────────────────────────────────────────────────────────
# Find these in your Stripe dashboard (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# and copy the printed whsec_... value here
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for your Pro product — create in Stripe dashboard
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Get your key at https://resend.com — free tier covers development
RESEND_API_KEY=re_...

# ─── File Uploads (Cloudinary) ─────────────────────────────────────────────────
# Get these at https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── App ───────────────────────────────────────────────────────────────────────
# Base URL used for OG images, emails, and redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron Security ─────────────────────────────────────────────────────────────
# Secures /api/github/cron and /api/analytics/cron endpoints.
# Set this as a Vercel cron secret or pass it via Authorization header.
CRON_SECRET=generate-with-openssl-rand-base64-32
